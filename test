function goTo(n){document.querySelectorAll('.form-section').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.step-tab').forEach((t,i)=>{t.classList.remove('active','completed');if(i<n)t.classList.add('completed')});document.getElementById('section-'+n).classList.add('active');document.querySelectorAll('.step-tab')[n].classList.add('active');window.scrollTo({top:0,behavior:'smooth'})}
function goToReview(){buildPreview();goTo(5)}

function handleBirthPlace(){const v=document.getElementById('birthPlaceType').value;const m={us_state:'birthUSStateField',us_territory:'birthUSTerritoryField',canadian_province:'birthCanadaField',mexican_state:'birthMexField',other_country:'birthOtherCountryField'};Object.keys(m).forEach(k=>{const el=document.getElementById(m[k]);if(el)el.style.display=(v===k)?'flex':'none'})}
function handleMarital(){const v=document.getElementById('maritalStatus').value;const show=v==='Married'||v==='Married/WID'||v==='SRDP'||v==='SRDP/SURV';document.getElementById('spouseSection').classList.toggle('show',show)}
function handleHispanic(){const v=document.getElementById('hispanic').value;document.getElementById('hispanicTypeWrap').style.display=(v==='YES')?'flex':'none';if(v!=='YES')document.getElementById('hispanicOtherWrap').classList.remove('show')}
function handleHispanicType(){const v=document.getElementById('hispanicType').value;document.getElementById('hispanicOtherWrap').classList.toggle('show',v==='Other')}
function handleParentBirth(p){const v=document.getElementById(p+'BirthType').value;document.getElementById(p+'StateWrap').style.display=(v==='us_state')?'flex':'none';document.getElementById(p+'MexWrap').style.display=(v==='mexican_state')?'flex':'none';document.getElementById(p+'CountryWrap').style.display=(v==='other_country')?'flex':'none'}
function handleInformantRel(){const v=document.getElementById('informantRel').value;document.getElementById('informantOtherWrap').style.display=(v==='Other')?'flex':'none'}
function checkOccupation(){const v=document.getElementById('occupation').value.trim().toLowerCase();document.getElementById('occupationErr').classList.toggle('show',['retired','retire','retiree','unemployed'].includes(v))}
function checkMaiden(){const d=document.getElementById('lastName').value.trim().toLowerCase();const s=document.getElementById('spouseLast').value.trim().toLowerCase();document.getElementById('maidenWarn').classList.toggle('show',d&&s&&d===s)}
function checkRaceSpecify(){const r=[document.getElementById('race1').value,document.getElementById('race2').value,document.getElementById('race3').value];const needsSpec=r.some(x=>x&&(x.includes('specify')||x==='Other, specify'));document.getElementById('raceSpecifyWrap').style.display=needsSpec?'block':'none'}

let countyTimer;
function autofillCounty(){clearTimeout(countyTimer);countyTimer=setTimeout(()=>{const zip=document.getElementById('zipCode').value.trim().replace(/\D/g,'').substring(0,5);const msg=document.getElementById('countyAutoMsg');if(zip.length===5&&ZIP_COUNTY[zip]){document.getElementById('county').value=ZIP_COUNTY[zip]+' County';msg.classList.add('show')}else{msg.classList.remove('show')}},400)}

const g=id=>{const el=document.getElementById(id);return el?el.value.trim():''};
function getBirth(){const t=g('birthPlaceType');if(t==='us_state')return g('birthUSState')||'—';if(t==='us_territory')return g('birthUSTerritory')+', US Territory';if(t==='canadian_province')return g('birthCanada')+', Canada';if(t==='mexican_state')return g('birthMex')+', Mexico';if(t==='other_country')return g('birthOtherCountry')||'—';if(t==='other_country_unk')return 'Other Country — Unknown';if(t==='unknown')return 'Unknown';return '—'}
function getParentBirth(p){const t=g(p+'BirthType');if(t==='us_state')return g(p+'State')||'—';if(t==='mexican_state')return g(p+'Mex')+', Mexico';if(t==='other_country')return g(p+'Country')||'—';if(t==='unknown')return 'Unknown';return '—'}
function getHispanic(){const h=g('hispanic');if(h==='NO')return 'No';if(h==='Unknown')return 'Unknown';if(h==='YES'){const t=g('hispanicType');return 'Yes — '+(t==='Other'?g('hispanicOther')||'Other':t||'—')}return '—'}
function getRace(){const r=[g('race1'),g('race2'),g('race3')].filter(Boolean).join(', ');const s=g('raceSpecify');return r+(s?' ('+s+')':'')||'—'}
function getMarital(){const raw=g('maritalStatus');return raw.split(' — ')[0]||'—'}
function calcAge(){const b=g('dob');if(!b)return '—';const bd=new Date(b),now=new Date();let a=now.getFullYear()-bd.getFullYear();if(now.getMonth()<bd.getMonth()||(now.getMonth()===bd.getMonth()&&now.getDate()<bd.getDate()))a--;return isNaN(a)?'—':String(a)}
function fmtDate(d){if(!d)return '';const[y,m,da]=d.split('-');return m+'/'+da+'/'+y}
function dash(s){return s||'—'}

function cell(label,value,cols){return`<div class="dc-cell"><div class="dc-cell-label">${label}</div><div class="dc-cell-value">${value||'—'}</div></div>`}

function buildPreview(){
  const p=document.getElementById('dcPreview');
  p.innerHTML=`<div class="dc-form">
<div class="dc-title">CERTIFICATE OF DEATH — FAMILY REVIEW</div>
<div class="dc-row" style="grid-template-columns:1fr 1fr 1fr">${cell('1. First Name',g('firstName'))}${cell('2. Middle Name',g('middleName')||'(none)')}${cell('3. Last Name',g('lastName')+' '+(g('suffix')||''))}</div>
<div class="dc-row" style="grid-template-columns:2fr 1fr 1fr 2fr">${cell('4. Date of Birth',fmtDate(g('dob')))}${cell('5. Age',calcAge())}${cell('6. Sex',g('sex'))}${cell('10. SSN',g('ssn'))}</div>
<div class="dc-row" style="grid-template-columns:2fr 2fr">${cell('9. Birthplace',getBirth())}${cell('AKA',g('akaName')||'(none)')}</div>
<div class="dc-row" style="grid-template-columns:2fr 2fr">${cell('11. Armed Forces',g('military'))}${cell('12. Marital Status',getMarital())}</div>
<div class="dc-row" style="grid-template-columns:1fr">${cell('13. Education',g('education'))}</div>
<div class="dc-row" style="grid-template-columns:2fr 2fr">${cell('14/15. Hispanic/Latino',getHispanic())}${cell('16. Race',getRace())}</div>
<div class="dc-row" style="grid-template-columns:2fr 2fr 1fr">${cell('17. Occupation',g('occupation'))}${cell('18. Industry',g('industry'))}${cell('19. Yrs',g('yearsOcc'))}</div>
<div class="dc-row" style="grid-template-columns:1fr">${cell('20–25. Residence',g('streetAddress')+' '+g('aptUnit')+' · '+g('city')+', '+g('resState')+' '+g('zipCode')+' · '+g('county')+' · '+g('yearsCounty')+' yrs')}</div>
<div class="dc-row" style="grid-template-columns:1fr 1fr">${cell('Mother',[g('motherFirst'),g('motherMiddle'),g('motherLast')].filter(Boolean).join(' '))}${cell("Mother's Birthplace",getParentBirth('mother'))}</div>
<div class="dc-row" style="grid-template-columns:1fr 1fr">${cell('Father',[g('fatherFirst'),g('fatherMiddle'),g('fatherLast')].filter(Boolean).join(' '))}${cell("Father's Birthplace",getParentBirth('father'))}</div>
<div class="dc-row" style="grid-template-columns:2fr 2fr">${cell('Informant',[g('informantFirst'),g('informantMiddle'),g('informantLast')].filter(Boolean).join(' '))}${cell('Relationship',g('informantRel')==='Other'?g('informantOther'):g('informantRel'))}</div>
<div class="dc-row" style="grid-template-columns:1fr 1fr">${cell('Primary Physician',g('physician1Name')+(g('physician1Phone')?' · '+g('physician1Phone'):''))}${cell('Additional Doctor',g('physician2Name')||(g('physician2Phone')?g('physician2Phone'):'N/A'))}</div>
</div>`}

async function submitForm(){
  const btn=document.getElementById('submitBtn');const status=document.getElementById('submitStatus');
  if(!g('firstName')||!g('lastName')){alert("Please complete your loved one's first and last name.");return}
  if(!g('sigName')){alert("Please type your full name to confirm the attestation.");return}
  btn.disabled=true;btn.textContent='Submitting…';status.textContent='Sending to Meadow…';status.classList.add('show');
  const ts=new Date().toLocaleString();
  const row=[ts,g('firstName'),g('middleName')||'-',g('lastName'),g('suffix')||'--',g('akaName'),fmtDate(g('dob')),calcAge(),g('sex'),g('ssn')||'UNK',getBirth(),g('military'),getMarital(),g('education'),getHispanic(),getRace(),g('occupation'),g('industry'),g('yearsOcc'),g('streetAddress'),g('aptUnit'),g('city'),g('county'),g('zipCode'),g('resState'),g('yearsCounty'),[g('motherFirst'),g('motherMiddle')||'-',g('motherLast')].join(' | '),getParentBirth('mother'),[g('fatherFirst'),g('fatherMiddle')||'-',g('fatherLast')].join(' | '),getParentBirth('father'),g('informantRel')==='Other'?g('informantOther'):g('informantRel'),[g('informantFirst'),g('informantMiddle')||'-',g('informantLast')].join(' | '),g('informantAddress'),g('physician1Name'),g('physician1Phone'),g('physician1Practice'),g('physician2Name'),g('physician2Phone'),g('physician2Practice'),g('sigName'),g('sigDate')];
  const URL='YOUR_APPS_SCRIPT_URL_HERE';
  try{
    if(URL==='YOUR_APPS_SCRIPT_URL_HERE'){await new Promise(r=>setTimeout(r,900));console.log('Demo mode — data:',row);showSuccess()}
    else{const r=await fetch(URL,{method:'POST',body:JSON.stringify({row}),headers:{'Content-Type':'application/json'}});if(!r.ok)throw new Error();showSuccess()}
  }catch(e){btn.disabled=false;btn.textContent='Submit to Meadow →';status.textContent='Submission failed — please try again.';status.style.color='var(--red)';console.error(e)}
}
function showSuccess(){document.getElementById('reviewContent').style.display='none';document.getElementById('successScreen').classList.add('show');document.querySelectorAll('.step-tab').forEach(t=>t.classList.add('completed'))}
</script>
